DATABASE_URL=mysql+pymysql://leave_user:leave_pass@localhost:3306/leave_db
JWT_SECRET=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

DEBUG=False
ENABLE_DOCS=True

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=LeaveOps HR
FRONTEND_URL=http://localhost:5173
INVITE_TOKEN_EXPIRE_HOURS=72

# Creates the first HR/superuser account automatically on a fresh database.
# Only fires once — safe to leave set permanently.
BOOTSTRAP_SUPERUSER_EMAIL=hr@example.com
BOOTSTRAP_SUPERUSER_PASSWORD=change_this_password
BOOTSTRAP_SUPERUSER_FULL_NAME=HR Admin
